<Window x:Class="ClaudeTracker.Views.FloatingUsageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="280">

    <Border Style="{StaticResource FloatingBorderStyle}" Padding="14,10,14,12"
            MouseLeftButtonDown="DragHandle_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Drag handle + close button -->
            <Grid x:Name="DragHandle" Grid.Row="0" Margin="0,0,0,8"
                  Cursor="SizeAll">
                <Grid.Background>
                    <SolidColorBrush Color="Transparent" />
                </Grid.Background>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Robot" Width="14" Height="14"
                                             Foreground="#888" Margin="0,0,5,0"
                                             VerticalAlignment="Center" />
                    <TextBlock Text="Claude Tracker" FontSize="11.5" FontWeight="Medium"
                               Foreground="#888" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Cursor="Arrow">
                    <Button x:Name="SwitchToPopoverButton" VerticalAlignment="Center"
                            Style="{StaticResource MaterialDesignIconButton}"
                            Width="22" Height="22" Padding="0"
                            ToolTip="Extend">
                        <materialDesign:PackIcon Kind="ArrowExpand" Width="13" Height="13" Foreground="#999" />
                    </Button>
                    <Button x:Name="DockButton" VerticalAlignment="Center"
                            Style="{StaticResource MaterialDesignIconButton}"
                            Width="22" Height="22" Padding="0"
                            ToolTip="Lock position">
                        <materialDesign:PackIcon x:Name="DockIcon" Kind="PinOutline"
                                                 Width="13" Height="13" Foreground="#999" />
                    </Button>
                    <Button x:Name="CloseButton" VerticalAlignment="Center"
                            Style="{StaticResource MaterialDesignIconButton}"
                            Width="22" Height="22" Padding="0"
                            ToolTip="Close widget">
                        <materialDesign:PackIcon Kind="Close" Width="14" Height="14" Foreground="#999" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Session Usage (subscription) -->
            <StackPanel x:Name="SessionPanel" Grid.Row="1" Margin="0,0,0,8">
                <Grid Margin="0,0,0,4">
                    <TextBlock Text="Session" FontSize="12" FontWeight="Medium" Foreground="#666" />
                    <TextBlock x:Name="SessionPercentText" HorizontalAlignment="Right"
                               FontSize="16" FontWeight="Bold" Foreground="#333" />
                </Grid>
                <Border Background="#15000000" CornerRadius="3" Height="6" ClipToBounds="True">
                    <Border x:Name="SessionProgressFill" Background="#4CAF50"
                            CornerRadius="3" HorizontalAlignment="Left" Width="0" />
                </Border>
                <Grid Margin="0,3,0,0">
                    <TextBlock x:Name="SessionResetText" FontSize="11" Foreground="#999" VerticalAlignment="Center" />
                    <StackPanel x:Name="SessionPacePanel" Orientation="Horizontal"
                                HorizontalAlignment="Right" Visibility="Collapsed"
                                Background="Transparent" Cursor="Help">
                        <TextBlock x:Name="SessionEstimateText" FontSize="10"
                                   VerticalAlignment="Center" Foreground="#999" Margin="0,0,4,0" />
                        <TextBlock x:Name="SessionPaceText" FontSize="10" VerticalAlignment="Center" Margin="0,0,3,0" />
                        <Ellipse x:Name="SessionPaceDot" Width="6" Height="6" VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Weekly Usage (subscription) -->
            <StackPanel x:Name="WeeklyPanel" Grid.Row="2" Margin="0,0,0,6">
                <Grid Margin="0,0,0,4">
                    <TextBlock Text="Weekly" FontSize="12" FontWeight="Medium" Foreground="#666" />
                    <TextBlock x:Name="WeeklyPercentText" HorizontalAlignment="Right"
                               FontSize="14" FontWeight="SemiBold" Foreground="#444" />
                </Grid>
                <Border Background="#15000000" CornerRadius="3" Height="5" ClipToBounds="True">
                    <Border x:Name="WeeklyProgressFill" Background="#4CAF50"
                            CornerRadius="3" HorizontalAlignment="Left" Width="0" />
                </Border>
                <Grid Margin="0,3,0,0">
                    <TextBlock x:Name="WeeklyResetText" FontSize="11" Foreground="#999" VerticalAlignment="Center" />
                    <StackPanel x:Name="WeeklyPacePanel" Orientation="Horizontal"
                                HorizontalAlignment="Right" Visibility="Collapsed"
                                Background="Transparent" Cursor="Help">
                        <TextBlock x:Name="WeeklyEstimateText" FontSize="10"
                                   VerticalAlignment="Center" Foreground="#999" Margin="0,0,4,0" />
                        <TextBlock x:Name="WeeklyPaceText" FontSize="10" VerticalAlignment="Center" Margin="0,0,3,0" />
                        <Ellipse x:Name="WeeklyPaceDot" Width="6" Height="6" VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Org Budget (API-only users) -->
            <StackPanel x:Name="ApiPanel" Grid.Row="1" Margin="0,0,0,8" Visibility="Collapsed">
                <Grid Margin="0,0,0,4">
                    <TextBlock Text="Org Budget" FontSize="12" FontWeight="Medium" Foreground="#666" />
                    <TextBlock x:Name="ApiPercentText" HorizontalAlignment="Right"
                               FontSize="16" FontWeight="Bold" Foreground="#333" />
                </Grid>
                <Border Background="#15000000" CornerRadius="3" Height="6" ClipToBounds="True">
                    <Border x:Name="ApiProgressFill" Background="#2196F3"
                            CornerRadius="3" HorizontalAlignment="Left" Width="0" />
                </Border>
                <TextBlock x:Name="ApiBudgetText" FontSize="11" Foreground="#999" Margin="0,3,0,0" />
            </StackPanel>

            <!-- My Usage (API-only users) -->
            <StackPanel x:Name="PersonalPanel" Grid.Row="2" Margin="0,0,0,6" Visibility="Collapsed">
                <TextBlock Text="My Usage" FontSize="12" FontWeight="Medium" Foreground="#666" Margin="0,0,0,4" />
                <!-- This Month -->
                <Border Background="#08000000" CornerRadius="4" Padding="8,5" Margin="0,0,0,3">
                    <Grid>
                        <TextBlock FontSize="11" Foreground="#888" VerticalAlignment="Center">
                            <Run Text="Month" FontWeight="Medium" />
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock x:Name="PersonalCostText" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#444" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock x:Name="PersonalSessionsText" FontSize="10"
                                       Foreground="#999" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
                <!-- Today -->
                <Border x:Name="FloatingDailyRow" Background="#08000000" CornerRadius="4"
                        Padding="8,5" Visibility="Collapsed">
                    <Grid>
                        <TextBlock FontSize="11" Foreground="#888" VerticalAlignment="Center">
                            <Run Text="Today" FontWeight="Medium" />
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock x:Name="FloatingDailyCostText" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#444" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock x:Name="FloatingDailyLinesText" FontSize="10"
                                       Foreground="#999" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Status -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
                <Ellipse x:Name="StatusDot" Width="6" Height="6" Margin="0,0,4,0" VerticalAlignment="Center" />
                <TextBlock x:Name="LastUpdatedText" FontSize="10" Foreground="#BBB" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
