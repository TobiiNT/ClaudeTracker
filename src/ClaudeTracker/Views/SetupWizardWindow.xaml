<Window x:Class="ClaudeTracker.Views.SetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Welcome to Claude Tracker"
        Width="500" Height="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesign.Brush.Background}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Content -->
        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Width="400" Margin="24,16,24,8">

            <!-- Step 1: Welcome -->
            <StackPanel x:Name="Step1" HorizontalAlignment="Center">
                <materialDesign:PackIcon Kind="Robot" Width="48" Height="48"
                                         HorizontalAlignment="Center" Margin="0,0,0,16"
                                         Foreground="{DynamicResource AccentTeal}" />
                <TextBlock Text="Welcome to Claude Tracker" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,8" />
                <TextBlock Text="Track your Claude AI usage right from your system tray."
                           FontSize="14" TextAlignment="Center" TextWrapping="Wrap"
                           Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                           Margin="0,0,0,24" />
            </StackPanel>

            <!-- Step 2: Connect -->
            <StackPanel x:Name="Step2" Visibility="Collapsed">
                <TextBlock Text="Connect Your Account" FontSize="18" FontWeight="Bold"
                           Margin="0,0,0,16" />

                <!-- Section: Subscription Plan -->
                <TextBlock Text="Using subscription plan?" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource TextMuted}" Margin="0,0,0,6" />

                <Border Style="{StaticResource UsageCardStyle}" Padding="14" Margin="0,0,0,16">
                    <Grid>
                        <StackPanel Margin="0,0,90,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <materialDesign:PackIcon Kind="Console" Width="16" Height="16"
                                                         Foreground="{DynamicResource AccentPurple}" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="Claude OAuth" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock x:Name="OAuthSubtitle" Text="Auto-detect from Claude Code"
                                       FontSize="11" Foreground="{DynamicResource TextSubtle}" TextWrapping="Wrap" />
                        </StackPanel>
                        <Button x:Name="AutoDetectButton" Content="Detect"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Height="32" FontSize="12" />
                    </Grid>
                </Border>

                <!-- Section: API Key -->
                <TextBlock Text="Using API key?" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource TextMuted}" Margin="0,0,0,6" />

                <Border Style="{StaticResource UsageCardStyle}" Padding="14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <materialDesign:PackIcon Kind="Web" Width="16" Height="16"
                                                     Foreground="{DynamicResource AccentBlue}" Margin="0,0,6,0" VerticalAlignment="Center" />
                            <TextBlock Text="API Console" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock x:Name="ApiSubtitle" Text="Track Claude Code spending from platform.claude.com"
                                   FontSize="11" Foreground="{DynamicResource TextSubtle}" TextWrapping="Wrap" Margin="0,0,0,10" />

                        <!-- Step 1: Session key -->
                        <StackPanel x:Name="ApiStep1">
                            <Grid Margin="0,0,0,8">
                                <TextBox x:Name="WizardKeyInput"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Session key..."
                                         FontFamily="Consolas" FontSize="11" Margin="0,0,80,0" />
                                <Button x:Name="ConnectButton" Content="Connect"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Height="32" FontSize="12" />
                            </Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button x:Name="AutoSignInButton" Height="28" FontSize="11"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Login" Width="14" Height="14"
                                 Margin="0,0,4,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Sign in to Console" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="OpenConsoleButton" Height="28" FontSize="11"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" 
                                        ToolTip="Open platform.claude.com with DevTools to copy sessionKey">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="OpenInNew" Width="14" Height="14"
                                                                 Margin="0,0,4,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Copy from Console" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <!-- Step 2: Organization picker -->
                        <StackPanel x:Name="ApiStep2" Visibility="Collapsed">
                            <TextBlock Text="Select Organization" FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource TextMuted}" Margin="0,0,0,6" />
                            <ComboBox x:Name="ApiOrgCombo"
                                      Style="{StaticResource MaterialDesignFilledComboBox}"
                                      DisplayMemberPath="DisplayName" FontSize="12" />
                        </StackPanel>

                        <!-- Step 3: User picker -->
                        <StackPanel x:Name="ApiStep3" Visibility="Collapsed">
                            <TextBlock Text="Select your identity" FontSize="12" FontWeight="Medium"
                                       Foreground="{DynamicResource TextMuted}" Margin="0,4,0,6" />
                            <Grid>
                                <ComboBox x:Name="ApiUserCombo"
                                          Style="{StaticResource MaterialDesignFilledComboBox}"
                                          DisplayMemberPath="DisplayName" FontSize="12"
                                          Margin="0,0,80,0" />
                                <Button x:Name="ApiConfirmButton" Content="Confirm"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Height="32" FontSize="12" />
                            </Grid>
                        </StackPanel>

                        <TextBlock x:Name="ApiTip" Visibility="Collapsed"
                                   FontSize="11" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" Margin="0,8,0,0"
                                   FontStyle="Italic" />

                        <ProgressBar x:Name="ApiLoading" IsIndeterminate="True" Visibility="Collapsed"
                                     Style="{StaticResource MaterialDesignLinearProgressBar}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <ProgressBar x:Name="WizardProgress" IsIndeterminate="True" Visibility="Collapsed"
                             Style="{StaticResource MaterialDesignLinearProgressBar}" Margin="0,4,0,0" />
            </StackPanel>

            <!-- Step 3: Done -->
            <StackPanel x:Name="Step3" Visibility="Collapsed" HorizontalAlignment="Center">
                <materialDesign:PackIcon Kind="CheckCircle" Width="48" Height="48"
                                         HorizontalAlignment="Center" Foreground="{DynamicResource StatusSafe}"
                                         Margin="0,0,0,16" />
                <TextBlock Text="All Set!" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,8" />
                <TextBlock Text="Claude Tracker is now monitoring your usage. Click the tray icon to see your dashboard."
                           FontSize="14" TextAlignment="Center" TextWrapping="Wrap"
                           Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
            </StackPanel>
        </StackPanel>

        <!-- Navigation buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="24,8,24,16">
            <Button x:Name="SkipButton" Content="Skip" Margin="0,0,8,0"
                    Style="{StaticResource MaterialDesignFlatButton}" Visibility="Collapsed" />
            <Button x:Name="NextButton" Content="Get Started"
                    Style="{StaticResource MaterialDesignRaisedButton}" />
        </StackPanel>
    </Grid>
</Window>
