<Window x:Class="ClaudeTracker.Views.NotificationPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True"
        ShowActivated="False"
        SizeToContent="WidthAndHeight" MaxWidth="360"
        ResizeMode="NoResize">
    <Border x:Name="PopupBorder" CornerRadius="10" Padding="14,12"
            Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
            BorderThickness="1" BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
            Cursor="Hand" MouseLeftButtonDown="Body_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="3" Opacity="0.4" BlurRadius="16" Direction="270" />
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Icon -->
            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8"
                    Background="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                    Margin="0,0,12,0" VerticalAlignment="Top">
                <TextBlock x:Name="IconText" Text="⚠" FontSize="18"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#FF9800" />
            </Border>

            <!-- Text -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="MessageText" FontSize="12"
                           Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                           TextWrapping="Wrap" Margin="0,2,0,0" />
            </StackPanel>

            <!-- Close button -->
            <Button Grid.Column="2" Content="✕" FontSize="11"
                    Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                    Background="Transparent" BorderThickness="0"
                    Width="22" Height="22" Padding="0" Margin="8,0,0,0"
                    VerticalAlignment="Top" Cursor="Hand"
                    Click="Close_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"
                                        Value="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Border>
</Window>
