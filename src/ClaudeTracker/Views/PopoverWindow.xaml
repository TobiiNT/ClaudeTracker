<Window x:Class="ClaudeTracker.Views.PopoverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:localization="clr-namespace:ClaudeTracker.Localization"
        xmlns:views="clr-namespace:ClaudeTracker.Views"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="330"
        MaxHeight="560">

    <Window.Resources>
        <views:ActivityIconConverter x:Key="ActivityIconConverter" />
    </Window.Resources>

    <Border Style="{StaticResource PopoverBorderStyle}" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ═══ Content body ═══ -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden"
                          Padding="16,10,16,6">
                <StackPanel x:Name="UsageCardsPanel">

                    <!-- No Credentials -->
                    <Border x:Name="NoCredentialsPanel" Visibility="Collapsed"
                            Style="{StaticResource UsageCardStyle}" Padding="20">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="KeyVariant" Width="36" Height="36"
                                                     HorizontalAlignment="Center" Margin="0,0,0,10"
                                                     Foreground="#999" />
                            <TextBlock Text="{x:Static localization:Strings.NoCredentials}" TextAlignment="Center"
                                       FontSize="15" FontWeight="SemiBold" Foreground="#555" />
                            <TextBlock Text="Open Settings to get started" TextAlignment="Center"
                                       FontSize="13" Margin="0,4,0,0" Foreground="#999" />
                        </StackPanel>
                    </Border>

                    <!-- Profile switcher (compact) -->
                    <Grid Margin="0,4,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <ComboBox x:Name="ProfileCombo"
                                      Style="{StaticResource MaterialDesignComboBox}"
                                      FontSize="14" Height="30" Padding="4,2"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      BorderThickness="0"
                                      Background="Transparent" />
                            <StackPanel Orientation="Horizontal" Margin="4,2,0,0">
                                <Ellipse x:Name="StatusDot" Width="7" Height="7" Margin="0,0,5,0" />
                                <TextBlock x:Name="StatusText" FontSize="12" Foreground="#888" />
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" x:Name="RefreshButton"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Width="30" Height="30" Padding="0"
                                VerticalAlignment="Top" Margin="0,1,0,0"
                                ToolTip="Refresh">
                            <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" Foreground="#777" />
                        </Button>
                    </Grid>

                    <!-- Claude Status Indicator (shown only during issues) -->
                    <Border x:Name="ClaudeStatusPanel" Visibility="Collapsed"
                            Background="#10FF9800" CornerRadius="6" Padding="8,5" Margin="0,0,0,6"
                            Cursor="Hand" MouseLeftButtonUp="ClaudeStatusPanel_Click">
                        <Border.ToolTip>
                            <TextBlock x:Name="ClaudeStatusTooltip" />
                        </Border.ToolTip>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="ClaudeStatusDot" Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center" />
                            <TextBlock x:Name="ClaudeStatusText" FontSize="12" VerticalAlignment="Center" />
                            <materialDesign:PackIcon Kind="OpenInNew" Width="12" Height="12"
                                                     Foreground="#999" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- ── Session Usage (primary, larger) ── -->
                    <Border x:Name="SessionCard" Style="{StaticResource UsageCardStyle}">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="{x:Static localization:Strings.SessionUsage}" FontSize="13.5" FontWeight="Medium" Foreground="#666" />
                                <TextBlock x:Name="SessionPercentText" HorizontalAlignment="Right"
                                           FontSize="24" FontWeight="Bold" Foreground="#333" />
                            </Grid>
                            <Grid Height="7">
                                <Border Background="#15000000" CornerRadius="3" ClipToBounds="True">
                                    <Border x:Name="SessionProgressFill" Background="#4CAF50"
                                            CornerRadius="3" HorizontalAlignment="Left" Width="0" />
                                </Border>
                                <Border x:Name="SessionTimeMarker" Width="2" HorizontalAlignment="Left"
                                        CornerRadius="1" Visibility="Collapsed" />
                            </Grid>
                            <Grid Margin="0,6,0,0">
                                <TextBlock x:Name="SessionResetText" FontSize="12" Foreground="#999" VerticalAlignment="Center" />
                                <StackPanel x:Name="SessionPacePanel" Orientation="Horizontal"
                                            HorizontalAlignment="Right" Visibility="Collapsed"
                                            Background="Transparent" Cursor="Help">
                                    <TextBlock x:Name="SessionEstimateText" FontSize="11"
                                               VerticalAlignment="Center" Foreground="#999" Margin="0,0,6,0" />
                                    <TextBlock x:Name="SessionPaceText" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <Ellipse x:Name="SessionPaceDot" Width="7" Height="7" VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── Weekly Usage ── -->
                    <Border x:Name="WeeklyCard" Style="{StaticResource UsageCardStyle}">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="{x:Static localization:Strings.WeeklyUsage}" FontSize="13" FontWeight="Medium" Foreground="#666" />
                                <TextBlock x:Name="WeeklyPercentText" HorizontalAlignment="Right"
                                           FontSize="17" FontWeight="SemiBold" Foreground="#444" />
                            </Grid>
                            <Grid Height="6">
                                <Border Background="#15000000" CornerRadius="3" ClipToBounds="True">
                                    <Border x:Name="WeeklyProgressFill" Background="#4CAF50"
                                            CornerRadius="3" HorizontalAlignment="Left" Width="0" />
                                </Border>
                                <Border x:Name="WeeklyTimeMarker" Width="2" HorizontalAlignment="Left"
                                        CornerRadius="1" Visibility="Collapsed" />
                            </Grid>
                            <Grid Margin="0,5,0,0">
                                <TextBlock x:Name="WeeklyResetText" FontSize="12" Foreground="#999" VerticalAlignment="Center" />
                                <StackPanel x:Name="WeeklyPacePanel" Orientation="Horizontal"
                                            HorizontalAlignment="Right" Visibility="Collapsed"
                                            Background="Transparent" Cursor="Help">
                                    <TextBlock x:Name="WeeklyEstimateText" FontSize="11"
                                               VerticalAlignment="Center" Foreground="#999" Margin="0,0,6,0" />
                                    <TextBlock x:Name="WeeklyPaceText" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <Ellipse x:Name="WeeklyPaceDot" Width="7" Height="7" VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── Model cards (side by side) ── -->
                    <Grid x:Name="ModelCardsGrid" Margin="0,0,0,0" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource UsageCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Opus" FontSize="12" FontWeight="Medium" Foreground="#888" />
                                <TextBlock x:Name="OpusPercentText" FontSize="18" FontWeight="Bold"
                                           Foreground="#444" Margin="0,2,0,4" />
                                <Border Background="#15000000" CornerRadius="2" Height="5" ClipToBounds="True">
                                    <Border x:Name="OpusProgressFill" Background="#7C4DFF"
                                            CornerRadius="2" HorizontalAlignment="Left" Width="0" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource UsageCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Sonnet" FontSize="12" FontWeight="Medium" Foreground="#888" />
                                <TextBlock x:Name="SonnetPercentText" FontSize="18" FontWeight="Bold"
                                           Foreground="#444" Margin="0,2,0,4" />
                                <Border Background="#15000000" CornerRadius="2" Height="5" ClipToBounds="True">
                                    <Border x:Name="SonnetProgressFill" Background="#00BCD4"
                                            CornerRadius="2" HorizontalAlignment="Left" Width="0" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ── Cost/Overage ── -->
                    <Border x:Name="CostCard" Style="{StaticResource UsageCardStyle}" Visibility="Collapsed">
                        <Grid>
                            <TextBlock Text="{x:Static localization:Strings.OverageCost}" FontSize="13" FontWeight="Medium" Foreground="#666" />
                            <TextBlock x:Name="CostText" HorizontalAlignment="Right"
                                       FontSize="16" FontWeight="SemiBold" Foreground="#444" />
                        </Grid>
                    </Border>

                    <!-- ── API Credits ── -->
                    <Border x:Name="ApiCard" Style="{StaticResource UsageCardStyle}" Visibility="Collapsed">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="{x:Static localization:Strings.APICredits}" FontSize="13" FontWeight="Medium" Foreground="#666" />
                                <TextBlock x:Name="ApiPercentText" HorizontalAlignment="Right"
                                           FontSize="17" FontWeight="SemiBold" Foreground="#444" />
                            </Grid>
                            <ProgressBar x:Name="ApiProgress" Style="{StaticResource UsageProgressBar}" />
                            <Grid Margin="0,5,0,0">
                                <TextBlock x:Name="ApiUsedText" FontSize="12" Foreground="#999" />
                                <TextBlock x:Name="ApiRemainingText" HorizontalAlignment="Right"
                                           FontSize="12" Foreground="#999" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── Active Claude Code Sessions ── -->
                    <Border x:Name="SessionsCard" Style="{StaticResource UsageCardStyle}" Visibility="Collapsed">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Console" Width="15" Height="15"
                                                             Foreground="#888" VerticalAlignment="Center"
                                                             Margin="0,0,5,0" />
                                    <TextBlock Text="Active Sessions" FontSize="13" FontWeight="Medium" Foreground="#666"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock x:Name="SessionCountText" HorizontalAlignment="Right"
                                           FontSize="13" FontWeight="SemiBold" Foreground="#444"
                                           VerticalAlignment="Center" />
                            </Grid>
                            <ItemsControl x:Name="SessionsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#08000000" CornerRadius="4" Padding="8,5" Margin="0,2"
                                                Cursor="Hand">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding ProjectName}" FontSize="12"
                                                               FontWeight="Medium" Foreground="#555"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding CurrentActivity}" FontSize="10.5"
                                                               Foreground="#999" TextTrimming="CharacterEllipsis"
                                                               Margin="0,1,0,0" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" FontSize="11" Foreground="#888"
                                                           VerticalAlignment="Center" Margin="0,0,6,0">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0}">
                                                            <Binding Path="ToolCallCount" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                                <Ellipse Grid.Column="2" Width="7" Height="7"
                                                         Fill="#4CAF50" VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- ── Recent Activity Feed ── -->
                    <Border x:Name="ActivityFeedCard" Style="{StaticResource UsageCardStyle}" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Recent Activity" FontSize="13" FontWeight="Medium"
                                       Foreground="#666" Margin="0,0,0,6" />
                            <ItemsControl x:Name="ActivityFeedList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontSize="10" Width="16"
                                                       FontFamily="Segoe UI Emoji"
                                                       Foreground="#888" VerticalAlignment="Center"
                                                       Text="{Binding Icon, Converter={StaticResource ActivityIconConverter}}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Summary}"
                                                       FontSize="11" Foreground="#666"
                                                       TextTrimming="CharacterEllipsis" Margin="2,0,0,0"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Last Updated (hidden — shown in status line above) -->
                    <TextBlock x:Name="LastUpdatedText" Visibility="Collapsed" />

                </StackPanel>
            </ScrollViewer>

            <!-- ═══ Footer — Warp style: branding left, icon buttons right ═══ -->
            <Border Grid.Row="2" Style="{StaticResource PopoverFooterStyle}" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="Robot" Width="16" Height="16"
                                                 Foreground="#888" Margin="0,0,6,0"
                                                 VerticalAlignment="Center" />
                        <TextBlock Text="Claude Tracker" FontSize="13" FontWeight="Medium"
                                   Foreground="#777" VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Cursor="Arrow">
                        <Button x:Name="SwitchToWidgetButton"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Width="28" Height="28" Padding="0"
                                ToolTip="Switch to floating widget">
                            <materialDesign:PackIcon Kind="OpenInNew" Width="17" Height="17" Foreground="#777" />
                        </Button>
                        <Button x:Name="SettingsButton"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Width="28" Height="28" Padding="0"
                                ToolTip="Settings">
                            <materialDesign:PackIcon Kind="CogOutline" Width="17" Height="17" Foreground="#777" />
                        </Button>
                        <Button x:Name="QuitButton"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Width="28" Height="28" Padding="0"
                                ToolTip="Quit">
                            <materialDesign:PackIcon Kind="Power" Width="17" Height="17" Foreground="#999" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
