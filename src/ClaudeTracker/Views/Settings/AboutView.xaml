<UserControl x:Class="ClaudeTracker.Views.Settings.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
        <StackPanel MaxWidth="480" HorizontalAlignment="Center">
            <!-- Logo area -->
            <materialDesign:PackIcon Kind="Robot" Width="64" Height="64"
                                     HorizontalAlignment="Center" Margin="0,20,0,12"
                                     Foreground="{DynamicResource PrimaryHueMidBrush}" />

            <TextBlock Text="Claude Tracker" FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,4" />
            <TextBlock x:Name="VersionText" FontSize="13"
                       HorizontalAlignment="Center" Margin="0,0,0,4"
                       Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
            <TextBlock Text="Claude AI usage tracker for Windows" FontSize="13"
                       HorizontalAlignment="Center" Margin="0,0,0,24"
                       Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />

            <!-- Update status -->
            <StackPanel x:Name="UpdatePanel" HorizontalAlignment="Center" Margin="0,0,0,16"
                        Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                    <materialDesign:PackIcon x:Name="UpdateIcon" Kind="Update" Width="18" Height="18"
                                             VerticalAlignment="Center" Margin="0,0,6,0"
                                             Foreground="{DynamicResource PrimaryHueMidBrush}" />
                    <TextBlock x:Name="UpdateStatusText" FontSize="13" VerticalAlignment="Center"
                               Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                    <ProgressBar x:Name="UpdateSpinner" IsIndeterminate="True"
                                 Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 Width="18" Height="18" Margin="8,0,0,0"
                                 VerticalAlignment="Center" Visibility="Collapsed" />
                </StackPanel>
                <Button x:Name="CheckUpdateButton" Content="Check for Updates"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,4" Width="200" Visibility="Collapsed" />
                <Button x:Name="ApplyUpdateButton" Content="Update &amp; Restart"
                        Style="{StaticResource MaterialDesignFlatMidBgButton}"
                        Margin="0,4" Width="200" Visibility="Collapsed" />
            </StackPanel>

            <!-- Actions -->
            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                <Button x:Name="GitHubButton" Content="View on GitHub"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,4" Width="200" />
                <Button x:Name="LogsButton" Content="Open Logs Folder"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,4" Width="200" />
            </StackPanel>

            <!-- Credits -->
            <TextBlock FontSize="11" HorizontalAlignment="Center"
                       Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}">
                <Run Text="Based on " /><Hyperlink x:Name="CreditsLink"
                    TextDecorations="None"
                    Foreground="{DynamicResource PrimaryHueMidBrush}">Claude Usage Tracker by hamed-elfayome</Hyperlink>
            </TextBlock>
        </StackPanel>
    </ScrollViewer>
</UserControl>
