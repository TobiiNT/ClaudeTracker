<UserControl x:Class="ClaudeTracker.Views.Settings.ClaudeOAuthView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
        <StackPanel MaxWidth="480">
            <TextBlock Text="Claude OAuth" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4" />
            <TextBlock Text="Sync Claude OAuth credentials"
                       FontSize="13" Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                       Margin="0,0,0,20" />

            <Border Style="{StaticResource UsageCardStyle}" Padding="16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <materialDesign:PackIcon x:Name="StatusIcon" Kind="Information"
                                                 Width="20" Height="20" Margin="0,0,8,0" />
                        <TextBlock x:Name="TokenStatusText" FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock x:Name="ExpiresText" FontSize="12" Margin="0,0,0,12"
                               Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />

                    <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,0,0,12"
                               Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}">
                        Reads Claude OAuth token from Windows Credential Manager
                        (stored by Claude Code).
                    </TextBlock>

                    <Button x:Name="SyncButton" Content="Sync Now"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            HorizontalAlignment="Left" Height="36" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
