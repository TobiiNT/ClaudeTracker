<UserControl x:Class="ClaudeTracker.Views.Settings.PersonalUsageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
        <StackPanel MaxWidth="480">
            <TextBlock Text="Claude.ai Subscription" FontSize="20" FontWeight="Bold" Margin="0,0,0,4" />
            <TextBlock Text="Track your Pro/Team/Enterprise usage cap (% remaining)"
                       FontSize="13" Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                       Margin="0,0,0,20" />

            <!-- Connected state -->
            <Border x:Name="ConnectedPanel" Visibility="Collapsed"
                    Style="{StaticResource UsageCardStyle}" Padding="16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <materialDesign:PackIcon Kind="CheckCircle" Foreground="#4CAF50"
                                                 Width="20" Height="20" Margin="0,0,8,0" />
                        <TextBlock x:Name="ConnectedText" FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock x:Name="ConnectedDetailText" FontSize="12" Margin="28,0,0,10"
                               Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                    <Button x:Name="DisconnectButton" Content="Disconnect"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            HorizontalAlignment="Left" Height="32" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Setup (not connected) -->
            <StackPanel x:Name="SetupPanel">
                <Border Style="{StaticResource UsageCardStyle}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Automatically syncs your Claude OAuth credentials."
                                   FontSize="12" Margin="0,0,0,10" TextWrapping="Wrap"
                                   Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="AutoDetectButton" Content="Connect"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Height="34" FontSize="12" />
                            <TextBlock x:Name="AutoDetectStatus" FontSize="12" Margin="12,0,0,0"
                                       VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="300" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <ProgressBar x:Name="LoadingBar" IsIndeterminate="True" Visibility="Collapsed"
                         Style="{StaticResource MaterialDesignLinearProgressBar}" Margin="0,8" />

            <!-- Claude Code API Usage Section -->
            <Border BorderThickness="0,0.5,0,0" BorderBrush="#22000000" Margin="0,24,0,0" />
            <TextBlock Text="Claude Code API Usage" FontSize="18" FontWeight="Bold" Margin="0,20,0,4" />
            <TextBlock Text="Track per-user Claude Code spending from API Console ($ cost)"
                       FontSize="13" Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                       Margin="0,0,0,16" />

            <!-- API Connected state -->
            <Border x:Name="ApiConnectedPanel" Visibility="Collapsed"
                    Style="{StaticResource UsageCardStyle}" Padding="16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <materialDesign:PackIcon Kind="CheckCircle" Foreground="#4CAF50"
                                                 Width="20" Height="20" Margin="0,0,8,0" />
                        <TextBlock x:Name="ApiConnectedText" FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Text="Connected" />
                    </StackPanel>
                    <TextBlock x:Name="ApiTrackedUserText" FontSize="12" Margin="28,0,0,8"
                               Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="ApiChangeUserButton" Content="Change User"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                HorizontalAlignment="Left" Height="32" FontSize="12" Margin="0,0,8,0" />
                        <Button x:Name="ApiDisconnectButton" Content="Disconnect"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                HorizontalAlignment="Left" Height="32" FontSize="12" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- API Setup (multi-step, same pattern as onboarding) -->
            <Border x:Name="ApiSetupPanel" Style="{StaticResource UsageCardStyle}" Padding="16">
                <StackPanel>
                    <TextBlock x:Name="ApiSubtitle" Text="Sign in to API Console to track Claude Code spending."
                               FontSize="12" Foreground="#999" TextWrapping="Wrap" Margin="0,0,0,10" />

                    <!-- Step 1: Session key -->
                    <StackPanel x:Name="ApiStep1">
                        <Grid Margin="0,0,0,8">
                            <TextBox x:Name="ApiKeyInput"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Session key..."
                                     FontFamily="Consolas" FontSize="12" Margin="0,0,80,0" />
                            <Button x:Name="ApiConnectButton" Content="Connect"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Height="34" FontSize="12" />
                        </Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button x:Name="ApiAutoSignInButton" Height="28" FontSize="11"
                                    Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Login" Width="14" Height="14"
                                                             Margin="0,0,4,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Sign in to Console" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="ApiOpenConsoleButton" Height="28" FontSize="11"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    ToolTip="Open platform.claude.com with DevTools to copy sessionKey">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="OpenInNew" Width="14" Height="14"
                                                             Margin="0,0,4,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Copy from Console" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <!-- Step 2: Organization picker -->
                    <StackPanel x:Name="ApiStep2" Visibility="Collapsed">
                        <TextBlock Text="Select Organization" FontSize="12" FontWeight="Medium"
                                   Foreground="#888" Margin="0,0,0,6" />
                        <ComboBox x:Name="ApiOrgCombo"
                                  Style="{StaticResource MaterialDesignFilledComboBox}"
                                  DisplayMemberPath="DisplayName" FontSize="12" />
                    </StackPanel>

                    <!-- Step 3: User picker -->
                    <StackPanel x:Name="ApiStep3" Visibility="Collapsed">
                        <TextBlock Text="Select your identity" FontSize="12" FontWeight="Medium"
                                   Foreground="#888" Margin="0,4,0,6" />
                        <Grid>
                            <ComboBox x:Name="ApiUserCombo"
                                      Style="{StaticResource MaterialDesignFilledComboBox}"
                                      DisplayMemberPath="DisplayName" FontSize="12"
                                      Margin="0,0,80,0" />
                            <Button x:Name="ApiConfirmButton" Content="Confirm"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Height="34" FontSize="12" />
                        </Grid>
                    </StackPanel>

                    <TextBlock x:Name="ApiTip" Visibility="Collapsed"
                               FontSize="11" Foreground="#888" TextWrapping="Wrap" Margin="0,8,0,0"
                               FontStyle="Italic" />

                    <ProgressBar x:Name="ApiLoadingBar" IsIndeterminate="True" Visibility="Collapsed"
                                 Style="{StaticResource MaterialDesignLinearProgressBar}" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
