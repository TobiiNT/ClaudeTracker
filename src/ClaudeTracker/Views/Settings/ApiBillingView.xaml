<UserControl x:Class="ClaudeTracker.Views.Settings.ApiBillingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
        <StackPanel MaxWidth="480">
            <TextBlock Text="Claude Code API Usage" FontSize="20" FontWeight="Bold" Margin="0,0,0,4" />
            <TextBlock Text="Track per-user Claude Code spending from API Console ($ cost)"
                       FontSize="13" Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                       Margin="0,0,0,20" />

            <Border x:Name="ConnectedPanel" Visibility="Collapsed"
                    Style="{StaticResource UsageCardStyle}" Padding="16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <materialDesign:PackIcon Kind="CheckCircle" Foreground="#4CAF50"
                                                 Width="20" Height="20" Margin="0,0,8,0" />
                        <TextBlock x:Name="ConnectedText" FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Text="Connected" />
                    </StackPanel>
                    <TextBlock x:Name="TrackedUserText" FontSize="12" Margin="28,0,0,8"
                               Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="ChangeUserButton" Content="Change User"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                HorizontalAlignment="Left" Height="32" FontSize="12" Margin="0,0,8,0" />
                        <Button x:Name="DisconnectButton" Content="Disconnect"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                HorizontalAlignment="Left" Height="32" FontSize="12" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock x:Name="ErrorText" FontSize="12" TextWrapping="Wrap" Margin="0,8,0,0"
                       Foreground="#F44336" />

            <StackPanel x:Name="SetupPanel">
                <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,0,0,12"
                           Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}">
                    <Run Text="1. Open " /><Run Text="platform.claude.com" FontWeight="SemiBold" />
                    <LineBreak />
                    <Run Text="2. Open DevTools (F12) → Application → Cookies" />
                    <LineBreak />
                    <Run Text="3. Copy the value of " /><Run Text="sessionKey" FontWeight="SemiBold" />
                </TextBlock>

                <TextBox x:Name="ApiKeyInput"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Session key..."
                         FontFamily="Consolas" FontSize="12"
                         Margin="0,0,0,12" />

                <Button x:Name="TestButton" Content="Test Connection"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        HorizontalAlignment="Left" Height="36" Margin="0,0,0,12" />

                <TextBlock x:Name="StatusText" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12" />

                <StackPanel x:Name="OrgPickerPanel" Visibility="Collapsed">
                    <TextBlock Text="Select Organization" FontSize="12" FontWeight="Medium" Margin="0,0,0,6"
                               Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                    <ComboBox x:Name="OrgCombo"
                              Style="{StaticResource MaterialDesignFilledComboBox}"
                              DisplayMemberPath="DisplayName"
                              Margin="0,0,0,12" />
                </StackPanel>

            </StackPanel>

            <ProgressBar x:Name="UserLoadingBar" IsIndeterminate="True" Visibility="Collapsed"
                         Style="{StaticResource MaterialDesignLinearProgressBar}" Margin="0,0,0,8" />

            <StackPanel x:Name="UserPickerPanel" Visibility="Collapsed">
                <TextBlock Text="Select your identity" FontSize="12" FontWeight="Medium" Margin="0,0,0,6"
                           Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                <ComboBox x:Name="UserCombo"
                          Style="{StaticResource MaterialDesignFilledComboBox}"
                          DisplayMemberPath="DisplayName"
                          Margin="0,0,0,12" />
                <Button x:Name="UserSaveButton" Content="Confirm"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        HorizontalAlignment="Left" Height="36" />
            </StackPanel>

            <ProgressBar x:Name="LoadingBar" IsIndeterminate="True" Visibility="Collapsed"
                         Style="{StaticResource MaterialDesignLinearProgressBar}" Margin="0,8" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
