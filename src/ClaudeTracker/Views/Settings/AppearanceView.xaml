<UserControl x:Class="ClaudeTracker.Views.Settings.AppearanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
        <StackPanel MaxWidth="480">
            <TextBlock Text="Appearance" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4" />
            <TextBlock Text="Customize the tray icon and theme"
                       FontSize="13" Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                       Margin="0,0,0,20" />

            <!-- Live Preview -->
            <Border Style="{StaticResource UsageCardStyle}" Padding="16" Margin="0,0,0,16">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Preview" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Center" Margin="0,0,0,10" />
                    <Border x:Name="PreviewBorder" Background="{DynamicResource SurfacePreview}" CornerRadius="6"
                            Padding="20,8" HorizontalAlignment="Center">
                        <Image x:Name="PreviewImage" Width="32" Height="32"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>
                    <TextBlock x:Name="PreviewLabel" FontSize="11" Foreground="{DynamicResource TextSubtle}"
                               HorizontalAlignment="Center" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <!-- Icon Style -->
            <TextBlock Text="Icon Style" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8" />
            <UniformGrid Columns="5" Margin="0,0,0,20">
                <RadioButton x:Name="StyleBattery" GroupName="IconStyle"
                             Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}"
                             Margin="2" HorizontalContentAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <Image x:Name="PreviewBatteryIcon" Width="24" Height="24" Margin="0,2"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Text="Battery" FontSize="10" HorizontalAlignment="Center" />
                    </StackPanel>
                </RadioButton>
                <RadioButton x:Name="StyleBar" GroupName="IconStyle"
                             Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}"
                             Margin="2" HorizontalContentAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <Image x:Name="PreviewBarIcon" Width="24" Height="24" Margin="0,2"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Text="Bar" FontSize="10" HorizontalAlignment="Center" />
                    </StackPanel>
                </RadioButton>
                <RadioButton x:Name="StylePercent" GroupName="IconStyle"
                             Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}"
                             Margin="2" HorizontalContentAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <Image x:Name="PreviewPercentIcon" Width="24" Height="24" Margin="0,2"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Text="%" FontSize="10" HorizontalAlignment="Center" />
                    </StackPanel>
                </RadioButton>
                <RadioButton x:Name="StyleRing" GroupName="IconStyle"
                             Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}"
                             Margin="2" HorizontalContentAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <Image x:Name="PreviewRingIcon" Width="24" Height="24" Margin="0,2"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Text="Ring" FontSize="10" HorizontalAlignment="Center" />
                    </StackPanel>
                </RadioButton>
                <RadioButton x:Name="StyleCompact" GroupName="IconStyle"
                             Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}"
                             Margin="2" HorizontalContentAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <Image x:Name="PreviewDotIcon" Width="24" Height="24" Margin="0,2"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Text="Dot" FontSize="10" HorizontalAlignment="Center" />
                    </StackPanel>
                </RadioButton>
            </UniformGrid>

            <!-- Theme -->
            <TextBlock Text="Theme" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8" />
            <ComboBox x:Name="ThemeCombo"
                      Style="{StaticResource MaterialDesignFilledComboBox}"
                      Margin="0,0,0,20" Width="200" HorizontalAlignment="Left"
                      Padding="12,6" materialDesign:ComboBoxAssist.ShowSelectedItem="True">
                <ComboBoxItem Content="System Default" Tag="auto" />
                <ComboBoxItem Content="Light" Tag="light" />
                <ComboBoxItem Content="Dark" Tag="dark" />
            </ComboBox>

            <!-- Icon Color -->
            <TextBlock Text="Icon Color" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8" />
            <WrapPanel x:Name="ColorSwatches" Margin="0,0,0,8" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="#" VerticalAlignment="Center" FontSize="13" Margin="0,0,4,0" />
                <TextBox x:Name="HexColorInput"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="FF9800"
                         FontFamily="Consolas" FontSize="12"
                         Width="100" MaxLength="6" />
                <Border x:Name="ColorPreviewSwatch" Width="28" Height="28"
                        CornerRadius="4" Margin="8,0,0,0" VerticalAlignment="Center"
                        BorderThickness="1" BorderBrush="#44000000" />
            </StackPanel>

            <!-- Toggles -->
            <Grid Margin="0,0,0,8">
                <TextBlock Text="Show remaining %" VerticalAlignment="Center" FontSize="13" />
                <ToggleButton x:Name="RemainingToggle" HorizontalAlignment="Right"
                              Style="{StaticResource CompactSwitch}" />
            </Grid>

            <!-- Save -->
            <Button x:Name="SaveButton" Content="Save Changes"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    HorizontalAlignment="Right" Height="36" FontSize="12"
                    Margin="0,12,0,0" Visibility="Collapsed" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
