<UserControl x:Class="ClaudeTracker.Views.Settings.GeneralSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:localization="clr-namespace:ClaudeTracker.Localization">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
        <StackPanel MaxWidth="480">
            <TextBlock Text="{x:Static localization:Strings.General}" FontSize="20" FontWeight="Bold" Margin="0,0,0,4" />
            <TextBlock Text="Configure refresh, startup, and notifications"
                       FontSize="13" Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                       Margin="0,0,0,20" />

            <!-- Refresh Interval -->
            <TextBlock Text="{x:Static localization:Strings.RefreshInterval}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4" />
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="60" />
                </Grid.ColumnDefinitions>
                <Slider x:Name="RefreshSlider" Minimum="10" Maximum="300"
                        TickFrequency="10" IsSnapToTickEnabled="True"
                        TickPlacement="BottomRight" />
                <TextBlock Grid.Column="1" x:Name="RefreshValueText" FontSize="13"
                           VerticalAlignment="Center" HorizontalAlignment="Center" />
            </Grid>

            <!-- Startup -->
            <TextBlock Text="{x:Static localization:Strings.Startup}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
            <Grid Margin="0,6,0,0">
                <StackPanel VerticalAlignment="Center" Margin="0,0,60,0">
                    <TextBlock Text="{x:Static localization:Strings.LaunchAtLogin}" FontSize="13" />
                    <TextBlock Text="Automatically start Claude Tracker when you log in to Windows"
                               FontSize="11" Foreground="#999" TextWrapping="Wrap" Margin="0,2,0,0" />
                </StackPanel>
                <ToggleButton x:Name="LaunchToggle" HorizontalAlignment="Right" VerticalAlignment="Center"
                              Style="{StaticResource CompactSwitch}" />
            </Grid>
            <Grid Margin="0,10,0,0">
                <StackPanel VerticalAlignment="Center" Margin="0,0,60,0">
                    <TextBlock Text="{x:Static localization:Strings.AutoStartSession}" FontSize="13" />
                    <TextBlock Text="When usage resets to 0%, automatically send a message to start a new session so tracking begins immediately"
                               FontSize="11" Foreground="#999" TextWrapping="Wrap" Margin="0,2,0,0" />
                </StackPanel>
                <ToggleButton x:Name="AutoStartToggle" HorizontalAlignment="Right" VerticalAlignment="Center"
                              Style="{StaticResource CompactSwitch}" />
            </Grid>
            <Grid Margin="0,10,0,20">
                <StackPanel VerticalAlignment="Center" Margin="0,0,60,0">
                    <TextBlock Text="{x:Static localization:Strings.CheckOverageLimit}" FontSize="13" />
                    <TextBlock Text="Track and display overage costs when you exceed your plan's included usage"
                               FontSize="11" Foreground="#999" TextWrapping="Wrap" Margin="0,2,0,0" />
                </StackPanel>
                <ToggleButton x:Name="OverageToggle" HorizontalAlignment="Right" VerticalAlignment="Center"
                              Style="{StaticResource CompactSwitch}" />
            </Grid>

            <!-- Time & Display -->
            <TextBlock Text="{x:Static localization:Strings.TimeAndDisplay}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
            <Grid Margin="0,6,0,0">
                <TextBlock Text="{x:Static localization:Strings.ResetTimeFormat}" VerticalAlignment="Center" FontSize="13" />
                <ComboBox x:Name="TimeDisplayCombo" HorizontalAlignment="Right" Width="160"
                          Style="{StaticResource MaterialDesignComboBox}" FontSize="12" />
            </Grid>
            <Grid Margin="0,10,0,20">
                <TextBlock Text="{x:Static localization:Strings.TimeFormat}" VerticalAlignment="Center" FontSize="13" />
                <ComboBox x:Name="TimeFormatCombo" HorizontalAlignment="Right" Width="160"
                          Style="{StaticResource MaterialDesignComboBox}" FontSize="12" />
            </Grid>

            <!-- Notifications -->
            <TextBlock Text="{x:Static localization:Strings.Notifications}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
            <Grid Margin="0,6,0,0">
                <TextBlock Text="{x:Static localization:Strings.EnableNotifications}" VerticalAlignment="Center" FontSize="13" />
                <ToggleButton x:Name="NotifyToggle" HorizontalAlignment="Right"
                              Style="{StaticResource CompactSwitch}" />
            </Grid>

            <StackPanel x:Name="ThresholdPanel" Margin="16,8,0,0">
                <Grid Margin="0,4">
                    <TextBlock Text="{x:Static localization:Strings.AlertAt75}" VerticalAlignment="Center" FontSize="12" />
                    <ToggleButton x:Name="Threshold75Toggle" HorizontalAlignment="Right"
                                  Style="{StaticResource CompactSwitch}" />
                </Grid>
                <Grid Margin="0,4">
                    <TextBlock Text="{x:Static localization:Strings.AlertAt90}" VerticalAlignment="Center" FontSize="12" />
                    <ToggleButton x:Name="Threshold90Toggle" HorizontalAlignment="Right"
                                  Style="{StaticResource CompactSwitch}" />
                </Grid>
                <Grid Margin="0,4">
                    <TextBlock Text="{x:Static localization:Strings.AlertAt95}" VerticalAlignment="Center" FontSize="12" />
                    <ToggleButton x:Name="Threshold95Toggle" HorizontalAlignment="Right"
                                  Style="{StaticResource CompactSwitch}" />
                </Grid>
            </StackPanel>

            <!-- Test Alert -->
            <Button x:Name="TestAlertButton" Content="{x:Static localization:Strings.SendTestAlert}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    HorizontalAlignment="Left" Height="34" FontSize="12"
                    Margin="16,12,0,0" />

            <!-- Save -->
            <Button x:Name="SaveButton" Content="{x:Static localization:Strings.SaveChanges}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    HorizontalAlignment="Right" Height="36" FontSize="12"
                    Margin="0,16,0,0" Visibility="Collapsed" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
