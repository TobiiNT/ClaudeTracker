<Window x:Class="ClaudeTracker.Views.HooksOnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="ClaudeTracker — Hooks Integration"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesign.Brush.Background}">
    <StackPanel Margin="32,28,32,24">
        <!-- Icon -->
        <materialDesign:PackIcon Kind="Connection" Width="40" Height="40"
                                 HorizontalAlignment="Center" Margin="0,0,0,16"
                                 Foreground="{DynamicResource PrimaryHueMidBrush}" />

        <!-- Title -->
        <TextBlock Text="Connect to Claude Code" FontSize="20" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,10" />

        <!-- Description -->
        <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="13"
                   Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                   Margin="0,0,0,16">
            Running multiple Claude sessions? Stop tab-switching
            to find which terminal needs your attention.
        </TextBlock>

        <!-- Benefits -->
        <StackPanel Margin="16,0,16,20">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <materialDesign:PackIcon Kind="ShieldCheck" Width="16" Height="16"
                                         Foreground="#7C4DFF" VerticalAlignment="Top" Margin="0,1,8,0" />
                <TextBlock TextWrapping="Wrap" FontSize="12"
                           Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}">
                    <Run FontWeight="SemiBold">Permission popups</Run> — approve tool calls from any window, no terminal switching
                </TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <materialDesign:PackIcon Kind="BellRing" Width="16" Height="16"
                                         Foreground="#2196F3" VerticalAlignment="Top" Margin="0,1,8,0" />
                <TextBlock TextWrapping="Wrap" FontSize="12"
                           Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}">
                    <Run FontWeight="SemiBold">Task notifications</Run> — know when Claude finishes without checking each session
                </TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="FormatListBulleted" Width="16" Height="16"
                                         Foreground="#4CAF50" VerticalAlignment="Top" Margin="0,1,8,0" />
                <TextBlock TextWrapping="Wrap" FontSize="12"
                           Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}">
                    <Run FontWeight="SemiBold">Activity feed</Run> — see all sessions at a glance from the tray icon
                </TextBlock>
            </StackPanel>
        </StackPanel>

        <!-- Status text (hidden by default, shown during install) -->
        <TextBlock x:Name="StatusText" FontSize="11" TextWrapping="Wrap"
                   HorizontalAlignment="Center" Margin="0,0,0,8"
                   Visibility="Collapsed" />
        <ProgressBar x:Name="ProgressBar" IsIndeterminate="True"
                     Style="{StaticResource MaterialDesignLinearProgressBar}"
                     Margin="0,0,0,16" Visibility="Collapsed" />

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="SkipButton" Content="Skip" Margin="0,0,12,0"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Height="36" FontSize="13" />
            <Button x:Name="SetupButton" Content="Enable &amp; Install"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Height="36" FontSize="13" />
        </StackPanel>
    </StackPanel>
</Window>
