<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Status Colors -->
    <SolidColorBrush x:Key="StatusSafeBrush" Color="#4CAF50" />
    <SolidColorBrush x:Key="StatusModerateBrush" Color="#FF9800" />
    <SolidColorBrush x:Key="StatusCriticalBrush" Color="#F44336" />

    <!-- Soft card background (semi-transparent for frosted look) -->
    <SolidColorBrush x:Key="SoftCardBackground" Color="#E8FFFFFF" />
    <SolidColorBrush x:Key="SoftCardBackgroundDark" Color="#E8202020" />
    <SolidColorBrush x:Key="SoftSeparator" Color="#1A000000" />
    <SolidColorBrush x:Key="SoftSeparatorDark" Color="#1AFFFFFF" />

    <!-- Usage card style - soft/rounded like macOS -->
    <Style x:Key="UsageCardStyle" TargetType="Border">
        <Setter Property="Background" Value="#0A000000" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="14" />
        <Setter Property="Margin" Value="0,4" />
    </Style>

    <!-- Progress bar styles - rounded, thicker -->
    <Style x:Key="UsageProgressBar" TargetType="ProgressBar" BasedOn="{StaticResource MaterialDesignLinearProgressBar}">
        <Setter Property="Height" Value="6" />
        <Setter Property="Minimum" Value="0" />
        <Setter Property="Maximum" Value="100" />
    </Style>

    <!-- Popover window style - clean Warp-like with soft shadow -->
    <Style x:Key="PopoverBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="#F5F5F5" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="BorderBrush" Value="#22000000" />
        <Setter Property="BorderThickness" Value="0.5" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect ShadowDepth="4" Opacity="0.22" BlurRadius="20" Direction="270" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Popover footer - Warp style bar -->
    <Style x:Key="PopoverFooterStyle" TargetType="Border">
        <Setter Property="Background" Value="#EEEEEE" />
        <Setter Property="CornerRadius" Value="0,0,14,14" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="BorderThickness" Value="0,0.5,0,0" />
        <Setter Property="BorderBrush" Value="#18000000" />
    </Style>

    <!-- Sidebar navigation button -->
    <Style x:Key="SidebarButton" TargetType="RadioButton" BasedOn="{StaticResource MaterialDesignFlatButton}">
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="Height" Value="40" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- Compact switch toggle (scaled down from default MaterialDesign) -->
    <Style x:Key="CompactSwitch" TargetType="ToggleButton"
           BasedOn="{StaticResource MaterialDesignSwitchToggleButton}">
        <Setter Property="LayoutTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="0.8" ScaleY="0.8" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Section header -->
    <Style x:Key="SectionHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
        <Setter Property="Margin" Value="16,12,16,4" />
    </Style>

</ResourceDictionary>
